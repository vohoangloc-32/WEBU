{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "removeComments": false,
    "showLineNumbers": false,
    "topFilesLength": 5
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "dist",
      "node_modules",
      "coverage",
      ".husky",
      "public/fonts/**",
      "**/*.svg",
      "**/*.png",
      "**/*.jpg"
    ]
  }
}
